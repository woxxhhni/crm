# ─────────────────────────────────────
# CLS Frontend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────

# Backend API (local Docker or dotnet run)
NEXT_PUBLIC_API_BASE_URL=http://localhost:40585

# reCAPTCHA (disabled in dev — no site key needed)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Timezone (IANA format)
NEXT_PUBLIC_TIMEZONE=America/Toronto
