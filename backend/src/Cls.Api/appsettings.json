{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "*** override with env ***"
  },
  "Jwt": {
    "Issuer": "Cls",
    "Audience": "ClsAudience",
    "Key": "*** override with secrets/env ***"
  },
  "ObjectStorage": {
    "Provider": "minio",
    "Bucket": "*** override with env ***"
  },
  "Minio": {
    "Endpoint": "*** override with env ***",
    "PublicEndpoint": "*** override with env ***",
    "UseSSL": false,
    "AccessKey": "*** override with env ***",
    "SecretKey": "*** override with env ***"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Recaptcha": {
    "Enabled": true,
    "SecretKey": "*** override with env ***",
    "Threshold": 0.5
  }
}