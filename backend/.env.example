# ─────────────────────────────────────
# CLS Backend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────

# System configuration
ASPNETCORE_ENVIRONMENT=Development
TZ=America/Toronto

# Ports mapping for docker-compose overrides
POSTGRES_HOST_PORT=5432
API_HOST_PORT=40585

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=Cls_Db

# JWT Settings
JWT_ISSUER=Cls
JWT_AUDIENCE=ClsAudience
JWT_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# MinIO Object Storage
MINIO_ROOT_USER=clsadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=cls-files
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Recaptcha
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=PLACEHOLDER_RECAPTCHA_SECRET_KEY_REPLACE_ME
RECAPTCHA_THRESHOLD=0.5
